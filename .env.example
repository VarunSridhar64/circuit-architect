# ── Circuit Architect Pro — Environment Variables ──
# Copy this to .env for local development
# On Railway: add these in the Variables tab

# AI API Keys — at least one required (Groq is faster/free)
GROQ_API_KEY=gsk_your_groq_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# JWT secret — change this to a long random string in production!
JWT_SECRET=change-me-to-a-long-random-string-in-production

# Port (Railway sets this automatically)
PORT=3000
